# Local mode
NEXT_PUBLIC_VECTOR_MOCK_MODE=true

# Optional local data directory override
# VECTOR_DATA_DIR=.vector-data

# V3 synthesis runtime (required; no deterministic synthesis fallback)
ADK_RUNTIME_URL=http://127.0.0.1:8081
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# V2/V3 source adapters (optional; app falls back to seeded snapshots when unset)
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=
AMPLITUDE_CHART_IDS=

TYPEFORM_API_KEY=
TYPEFORM_FORM_ID=
IOS_APP_ID=

# V4 publish integration (required for real Slack webhook publish)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#product-updates

# Optional future mode (non-MVP): Slack Web API chat.postMessage path
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_DEFAULT_CHANNEL_ID=C0123456789
